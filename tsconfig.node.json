{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "oxlint.config.ts",
    "oxfmt.config.ts"
  ],
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "types": ["node"],
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo"
  }
}
