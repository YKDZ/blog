    "remark-rehype": "catalog:",
    "shiki": "catalog:",
    "tailwindcss": "catalog:",
    "unified": "catalog:",
    "unist-util-visit": "catalog:",
    "vike": "catalog:",
    "vike-vue": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/typography": "catalog:",
    "@tailwindcss/vite": "catalog:",
