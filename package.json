  "scripts": {
    "check": "pnpm run fmt-check && pnpm run lint && pnpm run typecheck && pnpm run test",
    "dev": "vike dev",
    "build": "vike build",
    "fmt": "oxfmt --write",
    "fmt-check": "oxfmt --list-different",
    "lint": "oxlint --quiet --format=unix --config oxlint.config.ts",
    "lint:fix": "oxlint --format=unix --config oxlint.config.ts --fix",
    "test": "vitest run --reporter=agent --silent=passed-only",
    "write": "tsx src/scripts/new.ts",
    "typecheck": "tsc -b --noEmit --pretty false && vue-tsc --build --noEmit --pretty false"
  },
